# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

BAND_BASE_URL=https://app.band.ai
# URL de l'app Band pour ouvrir une Room dans le navigateur (lien « Ouvrir dans Band »)
BAND_WEB_APP_URL=https://app.band.ai
# BAND_ROOM_URL_TEMPLATE={base}/chat/{room_id}
# UUID de VOTRE compte Band (Settings → Profile) pour écrire APPROUVE/REJETE dans la Room
BAND_OWNER_USER_ID=

# --- 13 Remote Agents Band — voir docs/SETUP_BAND_13_AGENTS.md ---

BAND_SCANNER_AGENT_ID=
BAND_SCANNER_API_KEY=
BAND_SCANNER_HANDLE=

BAND_THREAT_AGENT_ID=
BAND_THREAT_API_KEY=
BAND_THREAT_HANDLE=

BAND_COMPLIANCE_AGENT_ID=
BAND_COMPLIANCE_API_KEY=
BAND_COMPLIANCE_HANDLE=

BAND_RISK_AGENT_ID=
BAND_RISK_API_KEY=
BAND_RISK_HANDLE=

BAND_DECISION_AGENT_ID=
BAND_DECISION_API_KEY=
BAND_DECISION_HANDLE=

BAND_FEASIBILITY_AGENT_ID=
BAND_FEASIBILITY_API_KEY=
BAND_FEASIBILITY_HANDLE=

BAND_ARCHITECT_AGENT_ID=
BAND_ARCHITECT_API_KEY=
BAND_ARCHITECT_HANDLE=

BAND_DESIGN_AGENT_ID=
BAND_DESIGN_API_KEY=
BAND_DESIGN_HANDLE=

BAND_DEV_AGENT_ID=
BAND_DEV_API_KEY=
BAND_DEV_HANDLE=

BAND_SECURITY_AGENT_ID=
BAND_SECURITY_API_KEY=
BAND_SECURITY_HANDLE=

BAND_QA_AGENT_ID=
BAND_QA_API_KEY=
BAND_QA_HANDLE=

BAND_METRICS_AGENT_ID=
BAND_METRICS_API_KEY=
BAND_METRICS_HANDLE=

BAND_REPORT_AGENT_ID=
BAND_REPORT_API_KEY=
BAND_REPORT_HANDLE=

# --- LLM (OpenRouter — Llama 3.3 70B free) : https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Modèles de repli OpenRouter (optionnel, séparés par des virgules)
OPENROUTER_MODEL_FALLBACKS=
OPENROUTER_TIMEOUT=180
OPENROUTER_MAX_TOKENS=2048

# Google AI Studio (repli optionnel) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# Repli interne (non affiché dans l'interface) — https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FALLBACKS=llama-3.1-8b-instant,gemma2-9b-it

# LLM — AI/ML API (MetricsAgent si clé + LLM_METRICS_USE_AIMLAPI=true)
AIMLAPI_API_KEY=
AIMLAPI_BASE_URL=https://api.aimlapi.com/v1
AIMLAPI_MODEL=anthropic/claude-3.5-sonnet

LLM_PROVIDER=featherless
# Repli explicite optionnel (vide = aucun repli)
LLM_FALLBACK_PROVIDER=
LLM_USE_AIMLAPI=false

# Featherless (open-source models) — DevAgent remediation / Mode B code gen
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=deepseek-ai/DeepSeek-V4-Pro
# Timeout par requête (s) et nb d'essais (retry auto sur timeout réseau)
FEATHERLESS_TIMEOUT=300
FEATHERLESS_MAX_RETRIES=2
LLM_METRICS_USE_AIMLAPI=false
LLM_DEV_USE_FEATHERLESS=true

# Réduction consommation tokens (dépôts GitHub / ZIP)
INGESTION_MAX_FILES=80
INGESTION_MAX_FILES_A=80
INGESTION_MAX_FILES_C=100
INGESTION_MAX_FILE_CHARS=8000
INGESTION_MAX_TOTAL_CHARS=120000
LLM_INITIAL_CONTENT_CHARS=45000
LLM_AGENT_RESULT_CHARS=8000
LLM_MAX_PROMPT_CHARS=35000

# Protection API (optionnel — vide = désactivé)
SECUREFLOW_API_KEY=

# GitHub (optionnel — évite les rate-limits pour l'ingestion)
# Créer un token : https://github.com/settings/tokens (scope public_repo)
# GITHUB_TOKEN=
GITHUB_REQUEST_TIMEOUT=60
GITHUB_FETCH_WORKERS=12
# Cache d'ingestion GitHub en mémoire (secondes) — 0 pour désactiver
GITHUB_CACHE_TTL=300
